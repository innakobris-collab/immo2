# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database (SQLite for MVP; switch to PostgreSQL for V1) ────────────────────
DATABASE_URL=sqlite+aiosqlite:///./immo2.db
# V1: DATABASE_URL=postgresql+asyncpg://immo2:password@localhost:5432/immo2

# ── Geocoding ─────────────────────────────────────────────────────────────────
NOMINATIM_USER_AGENT=immo2/0.1 (contact@immo2.de)
HERE_API_KEY=                          # optional, free tier at developer.here.com

# ── Feature flags (MVP: all off except playwright) ────────────────────────────
ENABLE_PHOTO_ANALYSIS=false            # enable when restb.ai contacted and contracted
ENABLE_LOCATION_API=false              # enable when Overpass H3 cache built
ENABLE_RENT_ML=false                   # enable when training data secured
ENABLE_PLAYWRIGHT=true                 # single-URL render (user-triggered only)

# ── Optional APIs (V1) ────────────────────────────────────────────────────────
RESTB_API_KEY=                         # from restb.ai after contract
EMPIRICA_API_KEY=                      # from empirica-regio.de after contract

# ── Cashflow defaults (overridable by user in UI) ─────────────────────────────
DEFAULT_EIGENKAPITAL_PCT=20.0
DEFAULT_FINANZIERUNGSZINS=3.5
DEFAULT_TILGUNG_PCT=2.0
DEFAULT_GRUNDANTEIL_PCT=25.0           # Grundanteil as % of Kaufpreis
DEFAULT_HAUSGELD_DEDUCTIBLE_PCT=65.0   # % of Hausgeld that is deductible
DEFAULT_MAKLER_PCT=3.57                # buyer side for investment properties

# ── GDPR ──────────────────────────────────────────────────────────────────────
REPORT_RETENTION_DAYS=90               # auto-delete after N days
